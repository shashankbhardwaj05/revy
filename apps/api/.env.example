# --- Core ---
PORT=4000
APP_BASE_URL=http://localhost:4000

# --- Recall.ai (Phase 1+) ---
RECALL_API_KEY=
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=

# --- Storage (Phase 2+) ---
# Homebrew Postgres uses your OS username as the default role, e.g. postgres://$(whoami)@localhost:5432/notetaker
DATABASE_URL=postgres://localhost:5432/notetaker
REDIS_URL=redis://localhost:6379

# --- AI summary + Drive export (Phase 4) ---
ANTHROPIC_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=
